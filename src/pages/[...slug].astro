---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('content', (entry) => {
    if (import.meta.env.PROD && entry.data.type === 'blog' && entry.data.draft) {
      return false;
    }
    return true;
  });

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { type, title, description, createdAt, updatedAt, tags } = entry.data;
---

<ContentLayout
  title={title}
  description={description}
  type={type}
  date={createdAt.toISOString().split('T')[0]}
  updatedAt={updatedAt ? updatedAt.toISOString().split('T')[0] : undefined}
  tags={tags}
  draft={type === 'blog' && entry.data.draft}
  category={type === 'wiki' ? entry.data.category : undefined}
  status={type === 'project' ? entry.data.status : undefined}
  url={type === 'project' ? entry.data.url : undefined}
  repo={type === 'project' ? entry.data.repo : undefined}
>
  <Content />
</ContentLayout>
